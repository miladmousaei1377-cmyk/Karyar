## کلیدهای API برای دستیار هوشمند کاریار
## این فایل را کپی کن به .env و کلیدهای واقعی را وارد کن
## .env در .gitignore قرار دارد - هرگز آن را commit نکن

# کلید Claude API (اجباری برای عملکرد دستیار)
CLAUDE_API_KEY=sk-ant-api03-...

# کلید OpenAI برای تبدیل صدا به متن (اختیاری - بدون آن ورودی صوتی غیرفعال می‌شود)
OPENAI_API_KEY=sk-...

# کلید ElevenLabs برای متن به صدا با کیفیت بالا (اختیاری - بدون آن از TTS سیستم استفاده می‌شود)
ELEVENLABS_API_KEY=

# کلید Tavily برای جستجوی وب (اختیاری)
TAVILY_API_KEY=tvly-...

# کلید OpenWeatherMap برای آب‌وهوا (اختیاری)
OPENWEATHER_API_KEY=
